# Ialemus Bridge — placeholder environment variables
# Copy to .env on the NAS and fill in real values locally.
# Never commit .env or real tokens to git.

# --- Ialemus Bridge server ---
IALEMUS_BRIDGE_PORT=8787
IALEMUS_BRIDGE_TOKEN=replace_me
IALEMUS_BRIDGE_BIND=0.0.0.0

# --- NAS host (for documentation / compose network references) ---
NAS_HOST=nas.local
NAS_LAN_URL=http://nas.local

# --- Music library roots (Ugreen volume paths — adjust to your setup) ---
NAS_MUSIC_ROOT=/volume1/Music
NAS_SPOTDL_DOWNLOADS=/volume1/Jellyfin/data/Music
NAS_METUBE_DOWNLOADS=/volume1/Jellyfin/data/MeTube
NAS_SLSKD_DOWNLOADS=/volume1/Jellyfin/data/Soulseek_Inbox/downloads

# --- Downstream service endpoints (LAN only) ---
SPOTDL_CONTAINER_NAME=spotdl
METUBE_BASE_URL=http://nas.local:8081
SLSKD_BASE_URL=http://nas.local:5030
SLSKD_API_KEY=replace_me

# --- Bridge behavior ---
BRIDGE_LOG_LEVEL=info
BRIDGE_JOB_RETENTION_DAYS=30
BRIDGE_WATCHER_DEBOUNCE_MS=5000
BRIDGE_ALLOWED_ORIGINS=

# --- Optional Android app build-time placeholders (not secrets) ---
# Used by CI or local docs only; real tokens are entered in app settings.
# IALEMUS_BRIDGE_URL=http://nas.local:8787/api
