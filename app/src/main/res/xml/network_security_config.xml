<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- LAN service URLs (MeTube, slskd, Bridge) are typically HTTP on private networks. -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
