<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/widget_hud_background"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/widget_brand"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="IALEMUS"
        android:textColor="#FF39FF14"
        android:textSize="11sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_status"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:text="STANDBY"
        android:textColor="#FF9B5CFF"
        android:textSize="10sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="No track loaded"
        android:textColor="#FFE8DEFF"
        android:textSize="14sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/widget_artist"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:maxLines="1"
        android:text="Standby"
        android:textColor="#B3E8DEFF"
        android:textSize="12sp" />

    <TextView
        android:id="@+id/widget_transport"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/widget_transport_chip"
        android:paddingHorizontal="10dp"
        android:paddingVertical="4dp"
        android:text="▶ OPEN"
        android:textColor="#FF39FF14"
        android:textSize="11sp"
        android:textStyle="bold" />

</LinearLayout>
